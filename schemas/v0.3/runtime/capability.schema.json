{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mdbase.dev/schemas/runtime/v0.1/capability.schema.json",
  "title": "mdbase runtime capability contract",
  "type": "object",
  "required": ["type", "id", "version", "name"],
  "properties": {
    "type": {
      "const": "capability"
    },
    "id": {
      "$ref": "#/$defs/identifier"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "provider": {
      "$ref": "#/$defs/identifier"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "risk": {
      "enum": ["low", "medium", "high", "destructive"]
    },
    "effects": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/identifier"
      }
    }
  },
  "patternProperties": {
    "^x-[A-Za-z0-9._:-]+$": true
  },
  "additionalProperties": false,
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9._:-]*$"
    }
  }
}
